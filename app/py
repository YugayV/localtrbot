def auto_trade():
    while True:
        try:
            now = datetime.now()
            prices = {}

            for pair, ticker in PAIRS.items():
                d = get_data(ticker)
                if d is None or d.empty:
                    continue
                ind = get_indicators(d, pair)
                prices[pair] = float(ind["price"])
                current_prices[pair] = ind

            if prices and any(p.get("status") == "OPEN" for p in account.positions):
                closed = account.check_all_positions(prices)
                if closed:
                    text = "<b>CLOSED:</b>\n"
                    for pos in closed:
                        text += f"{pos.get('pair','?')}: {pos.get('status','?')} ${float(pos.get('pnl', 0) or 0):+.2f}\n"
                    notify(text)

            with config_lock:
                enabled = bool(CONFIG.get("auto_trade_enabled", True))
                trades_per_pair = int(CONFIG["trades_per_pair"])
                interval = int(CONFIG["check_interval"])

            for pair, ticker in PAIRS.items():
                if not enabled:
                    break
                if len([p for p in account.positions if p.get("pair") == pair and p.get("status") == "OPEN"]) >= trades_per_pair:
                    continue
                d = get_data(ticker)
                if d is None or d.empty:
                    continue
                ind = get_indicators(d, pair)

                sig, sigs = check_signal(ind, enforce_hours=True)
                if sig != 0 and len(sigs) >= 2:
                    pos = account.open_trade(sig, ind)
                    account.save_state()
                    direction = "LONG" if sig == 1 else "SHORT"
                    notify(
                        f"AUTO [{direction}]\n\n"
                        f"Pair: {pair}\n"
                        f"Entry: {fp(pair, ind)}\n\n" + "\n".join(f"- {s}" for s in sigs)
                    )

            if (now - account.last_report).seconds >= 3600:
                st = account.stats()
                text = f"<b>HOURLY</b>\n\nBalance: ${st['balance']:.2f}\nReturn: {st['return']:+.2f}%\nOpen: {st['open']}\n"
                if any(p.get("status") == "OPEN" for p in account.positions):
                    text += "\nPositions:\n"
                    for p in account.positions:
                        if p.get("status") == "OPEN":
                            text += f"- {p.get('pair','?')}\n"
                notify(text)
                account.last_report = now
                account.save_state()

            time.sleep(max(1, interval))

        except Exception:
            time.sleep(60)


def run_bot_polling():
    try:
        bot.polling(none_stop=True)
    except Exception:
        pass


def run_http_server():
    port = int(os.environ.get("PORT", "8080") or 8080)
    server = ThreadingHTTPServer(("0.0.0.0", port), DashboardHandler)
    server.serve_forever()


def main():
    t1 = threading.Thread(target=auto_trade, daemon=True)
    t1.start()

    t2 = threading.Thread(target=run_bot_polling, daemon=True)
    t2.start()

    run_http_server()


if __name__ == "__main__":
    main()