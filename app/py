@bot.message_handler(commands=["signal"])
def signal(m):
    text = "<b>Signals:</b>\n\n"
    best = None
    best_count = 0

    for pair, ticker in PAIRS.items():
        d = get_data(ticker)
        if d is None or d.empty:
            continue
        ind = get_indicators(d, pair)
        sig, sigs = check_signal(ind, enforce_hours=False)

        if sig != 0:
            direction = "BUY" if sig == 1 else "SELL"
            text += f"{pair}: <b>{direction}</b> RSI:{ind['rsi']:.0f}\n"
            if len(sigs) > best_count:
                best_count = len(sigs)
                best = (pair, sig, ind, sigs)

    if best:
        pair, sig, ind, sigs = best
        text += f"\n<b>BEST: {pair}</b>\n"
        text += f"Entry: {fp(pair, ind)}\n"

    bot.reply_to(m, text if ("BUY" in text or "SELL" in text) else "No signals.", parse_mode="HTML")


@bot.message_handler(commands=["trade"])
def trade(m):
    best = None
    best_count = 0

    with config_lock:
        max_per_pair = int(CONFIG["trades_per_pair"])

    for pair, ticker in PAIRS.items():
        if len([p for p in account.positions if p.get("pair") == pair and p.get("status") == "OPEN"]) >= max_per_pair:
            continue
        d = get_data(ticker)
        if d is None or d.empty:
            continue
        ind = get_indicators(d, pair)
        sig, sigs = check_signal(ind, enforce_hours=False)
        if sig != 0 and len(sigs) > best_count:
            best_count = len(sigs)
            best = (pair, sig, ind, sigs)

    if best is None:
        bot.reply_to(m, "No signals!")
        return

    pair, sig, ind, sigs = best
    pos = account.open_trade(sig, ind)
    direction = "LONG" if sig == 1 else "SHORT"

    notify(
        f"TRADE [{direction}]\n\n"
        f"Pair: {pair}\n"
        f"Entry: {fp(pair, ind)}\n\n"
        "Signals:\n" + "\n".join(f"- {s}" for s in sigs)
    )

    msg = (
        f"TRADE [{direction}]\n\n"
        f"Pair: {pair}\n"
        f"Entry: {fp(pair, ind)}\n"
        f"SL: {fmt_price(pair, pos['sl'])}\n"
        f"TP: {fmt_price(pair, pos['tp'])}\n"
        f"Risk: ${pos['risk']:.2f}\n\n"
        f"Balance: ${account.balance:.2f}"
    )
    bot.reply_to(m, msg)


